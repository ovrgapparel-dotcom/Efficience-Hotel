{
  "installCommand": "cd hotel-mobile && npm install",
  "buildCommand": "cd hotel-mobile && npx expo export --platform web --output-dir ../dist",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
